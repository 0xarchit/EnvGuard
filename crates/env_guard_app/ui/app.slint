import { Palette, Typography, Tokens } from "theme.slint";
import { PrimaryButton, SecondaryButton, DangerButton, IconButton, InputField, PasswordField } from "components.slint";
import { ProfileUiData, CredentialUiData, SessionUiData, Sidebar, UnlockView, ProfileCard } from "views.slint";

export { ProfileUiData, CredentialUiData, SessionUiData }

export component AppWindow inherits Window {
    title: "EnvGuard";
    icon: @image-url("../icons/logo.png");
    min-width: 900px;
    min-height: 600px;
    preferred-width: 1100px;
    preferred-height: 720px;
    background: Palette.bg-base;
    in-out property <int> active-nav: 0;
    in-out property <bool> vault-locked: true;
    in-out property <bool> vault-initialized: true;
    in-out property <string> error-message: "";
    in-out property <int> active-session-count: 0;
    in-out property <[ProfileUiData]> profiles: [];
    in-out property <[CredentialUiData]> credentials: [];
    in-out property <[SessionUiData]> active-sessions: [];
    in-out property <[string]> scanned-env-files: [];
    in-out property <string> selected-profile-id: "";
    in-out property <string> selected-profile-name: "";
    in-out property <string> new-profile-name: "";
    in-out property <string> new-profile-desc: "";
    in-out property <string> new-credential-key: "";
    in-out property <string> new-credential-val: "";
    in-out property <string> new-cred-key: "";
    in-out property <string> new-cred-val: "";
    in-out property <string> scan-directory: "";
    in-out property <string> session-timeout: "";
    in-out property <string> allowed-shells: "";

    callback unlock(string);
    callback lock-vault;
    callback create-profile(string, string);
    callback select-profile(string);
    callback delete-profile(string);
    callback add-credential(string, string, string);
    callback delete-credential(string);
    callback copy-to-clipboard(string);
    callback decrypt-credential(string) -> string;
    callback start-session(string);
    callback stop-session(string);
    callback scan-env-files(string);
    callback save-profile-rules(string, string, string);
    callback reset-vault;

    if vault-locked: UnlockView {
        error-text: root.error-message;
        vault-initialized: root.vault-initialized;
        unlock(pw) => { root.unlock(pw); }
        reset-vault => { root.reset-vault(); }
    }
    if !vault-locked: HorizontalLayout {
        Sidebar {
            active-item: root.active-nav;
            active-session-count: root.active-session-count;
            navigate(item) => {
                root.active-nav = item;
                root.selected-profile-id = "";
            }
            lock-vault => { root.lock-vault(); }
        }
        Rectangle { width: 1px; background: Palette.border-subtle; }
        Rectangle {
            background: Palette.bg-base;
            horizontal-stretch: 1;
            if active-nav == 0 && selected-profile-id == "": VerticalLayout {
                padding: Tokens.space-6;
                spacing: Tokens.space-4;
                alignment: start;
                Text {
                    text: "Project Profiles";
                    font-size: Typography.size-xl;
                    font-weight: Typography.weight-semibold;
                    color: Palette.text-primary;
                    height: 32px;
                }
                Rectangle { height: 1px; background: Palette.border-subtle; }
                HorizontalLayout {
                    spacing: Tokens.space-3;
                    InputField {
                        placeholder: "Profile name (e.g. WebApp)";
                        value <=> root.new-profile-name;
                        width: 200px;
                    }
                    InputField {
                        placeholder: "Description (e.g. Dev keys)";
                        value <=> root.new-profile-desc;
                        width: 300px;
                    }
                    PrimaryButton {
                        text: "Create Profile";
                        clicked => {
                            root.create-profile(root.new-profile-name, root.new-profile-desc);
                            root.new-profile-name = "";
                            root.new-profile-desc = "";
                        }
                        y: 10px;
                    }
                }
                Rectangle { height: 1px; background: Palette.border-subtle; }
                if profiles.length == 0: Text {
                    text: "No project profiles found. Initialize one using the workspace bar above.";
                    font-size: Typography.size-base;
                    color: Palette.text-secondary;
                }
                VerticalLayout {
                    spacing: Tokens.space-3;
                    for p in profiles: ProfileCard {
                        profile: p;
                        clicked => {
                            root.selected-profile-id = p.id;
                            root.selected-profile-name = p.name;
                            root.select-profile(p.id);
                        }
                        start-session => {
                            root.start-session(p.id);
                        }
                    }
                }
            }
            if active-nav == 0 && selected-profile-id != "": VerticalLayout {
                padding: Tokens.space-6;
                spacing: Tokens.space-4;
                alignment: start;
                HorizontalLayout {
                    spacing: Tokens.space-4;
                    alignment: start;
                    SecondaryButton {
                        text: "← Profiles";
                        clicked => { root.selected-profile-id = ""; }
                    }
                    Text {
                        text: "Workspace: " + root.selected-profile-name;
                        font-size: Typography.size-xl;
                        font-weight: Typography.weight-semibold;
                        color: Palette.text-primary;
                        y: 2px;
                    }
                }
                Rectangle { height: 1px; background: Palette.border-subtle; }
                HorizontalLayout {
                    spacing: Tokens.space-3;
                    InputField {
                        placeholder: "Timeout (seconds)";
                        value <=> root.session-timeout;
                        width: 150px;
                    }
                    InputField {
                        placeholder: "Allowed Shells (e.g. Cmd, Bash)";
                        value <=> root.allowed-shells;
                        width: 250px;
                    }
                    PrimaryButton {
                        text: "Save Rules";
                        clicked => {
                            root.save-profile-rules(root.selected-profile-id, root.session-timeout, root.allowed-shells);
                        }
                        y: 10px;
                    }
                }
                Rectangle { height: 1px; background: Palette.border-subtle; }
                HorizontalLayout {
                    spacing: Tokens.space-3;
                    InputField {
                        placeholder: "Key (e.g. API_KEY)";
                        value <=> root.new-cred-key;
                        width: 180px;
                    }
                    InputField {
                        placeholder: "Value";
                        value <=> root.new-cred-val;
                        width: 240px;
                    }
                    PrimaryButton {
                        text: "Add Secret";
                        clicked => {
                            root.add-credential(root.selected-profile-id, root.new-cred-key, root.new-cred-val);
                            root.new-cred-key = "";
                            root.new-cred-val = "";
                        }
                        y: 10px;
                    }
                }
                Rectangle { height: 1px; background: Palette.border-subtle; }
                if credentials.length == 0: Text {
                    text: "No credentials registered inside this workspace yet.";
                    font-size: Typography.size-base;
                    color: Palette.text-secondary;
                }
                VerticalLayout {
                    spacing: Tokens.space-2;
                    for c in credentials: Rectangle {
                        height: 38px;
                        background: Palette.bg-surface;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: Palette.border-default;
                        HorizontalLayout {
                            padding-left: Tokens.space-4;
                            padding-right: Tokens.space-4;
                            spacing: Tokens.space-4;
                            alignment: space-between;
                            Text {
                                text: c.key;
                                font-size: Typography.size-base;
                                font-weight: Typography.weight-semibold;
                                color: Palette.text-primary;
                                width: 220px;
                                y: (parent.height - self.height) / 2;
                            }
                            Text {
                                text: c.value-revealed ? c.value-plaintext : "••••••••••••";
                                font-size: Typography.size-base;
                                color: Palette.text-secondary;
                                width: 250px;
                                y: (parent.height - self.height) / 2;
                            }
                            HorizontalLayout {
                                spacing: Tokens.space-2;
                                alignment: end;
                                VerticalLayout {
                                    alignment: center;
                                    SecondaryButton {
                                        text: c.value-revealed ? "Hide" : "Reveal";
                                        clicked => {
                                            if (!c.value-revealed) {
                                                c.value-plaintext = root.decrypt-credential(c.id);
                                            } else {
                                                c.value-plaintext = "";
                                            }
                                            c.value-revealed = !c.value-revealed;
                                        }
                                        height: 24px;
                                        min-width: 64px;
                                    }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    SecondaryButton {
                                        text: "Copy";
                                        clicked => { root.copy-to-clipboard(c.id); }
                                        height: 24px;
                                        min-width: 54px;
                                    }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    DangerButton {
                                        text: "Delete";
                                        clicked => { root.delete-credential(c.id); }
                                        height: 24px;
                                        min-width: 54px;
                                    }
                                }
                            }
                        }
                    }
                }
            }
            if active-nav == 1: VerticalLayout {
                padding: Tokens.space-6;
                spacing: Tokens.space-4;
                alignment: start;
                Text {
                    text: "Active Runtime Sessions";
                    font-size: Typography.size-xl;
                    font-weight: Typography.weight-semibold;
                    color: Palette.text-primary;
                    height: 32px;
                }
                Rectangle { height: 1px; background: Palette.border-subtle; }
                if active-sessions.length == 0: Text {
                    text: "No active terminal sessions. Launch one from the Profiles tab.";
                    font-size: Typography.size-base;
                    color: Palette.text-secondary;
                }
                VerticalLayout {
                    spacing: Tokens.space-2;
                    for s in active-sessions: Rectangle {
                        height: 48px;
                        background: Palette.bg-surface;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: Palette.border-default;
                        HorizontalLayout {
                            padding-left: Tokens.space-4;
                            padding-right: Tokens.space-4;
                            spacing: Tokens.space-4;
                            alignment: space-between;
                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: s.shell;
                                    font-size: Typography.size-base;
                                    font-weight: Typography.weight-semibold;
                                    color: Palette.text-primary;
                                }
                                Text {
                                    text: "Started: " + s.started-at;
                                    font-size: Typography.size-xs;
                                    color: Palette.text-secondary;
                                }
                            }
                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: "PID: " + s.pid;
                                    font-size: Typography.size-sm;
                                    color: Palette.text-secondary;
                                }
                                Text {
                                    text: s.expires-at != "" ? "Expires: " + s.expires-at : "Persistent Session";
                                    font-size: Typography.size-xs;
                                    color: Palette.text-muted;
                                }
                            }
                            VerticalLayout {
                                alignment: center;
                                DangerButton {
                                    text: "Terminate";
                                    clicked => { root.stop-session(s.id); }
                                    height: 24px;
                                }
                            }
                        }
                    }
                }
            }
            if active-nav == 2: VerticalLayout {
                padding: Tokens.space-6;
                spacing: Tokens.space-4;
                alignment: start;
                Text {
                    text: ".env Scanner";
                    font-size: Typography.size-xl;
                    font-weight: Typography.weight-semibold;
                    color: Palette.text-primary;
                    height: 32px;
                }
                Rectangle { height: 1px; background: Palette.border-subtle; }
                HorizontalLayout {
                    spacing: Tokens.space-3;
                    InputField {
                        placeholder: "Absolute workspace path";
                        value <=> root.scan-directory;
                        width: 400px;
                    }
                    PrimaryButton {
                        text: "Scan Directory";
                        clicked => { root.scan-env-files(root.scan-directory); }
                        y: 10px;
                    }
                }
                Rectangle { height: 1px; background: Palette.border-subtle; }
                if scanned-env-files.length == 0: Text {
                    text: "Specify a local directory path to scan for insecure dot-env variables.";
                    font-size: Typography.size-base;
                    color: Palette.text-secondary;
                }
                VerticalLayout {
                    spacing: Tokens.space-2;
                    for f in scanned-env-files: Rectangle {
                        height: 38px;
                        background: Palette.bg-surface;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: Palette.border-default;
                        HorizontalLayout {
                            padding-left: Tokens.space-4;
                            padding-right: Tokens.space-4;
                            alignment: space-between;
                            Text {
                                text: f;
                                font-size: Typography.size-sm;
                                color: Palette.text-secondary;
                                y: (parent.height - self.height) / 2;
                            }
                        }
                    }
                }
            }
            if active-nav == 3: VerticalLayout {
                padding: Tokens.space-6;
                spacing: Tokens.space-4;
                alignment: start;
                Text {
                    text: "System Settings";
                    font-size: Typography.size-xl;
                    font-weight: Typography.weight-semibold;
                    color: Palette.text-primary;
                    height: 32px;
                }
                Rectangle { height: 1px; background: Palette.border-subtle; }
                VerticalLayout {
                    spacing: Tokens.space-2;
                    Text {
                        text: "Vault Storage Engine";
                        font-size: Typography.size-base;
                        font-weight: Typography.weight-semibold;
                        color: Palette.text-primary;
                    }
                    Text {
                        text: "Engine: SQLCipher (AES-256-GCM page-encrypted SQLite database)";
                        font-size: Typography.size-sm;
                        color: Palette.text-secondary;
                    }
                    Text {
                        text: "Key Hashing KDF: Argon2id (m_cost=65536, t_cost=3, p_cost=4)";
                        font-size: Typography.size-sm;
                        color: Palette.text-secondary;
                    }
                }
            }
        }
    }
}
