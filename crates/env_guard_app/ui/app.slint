import { Palette, Typography, Tokens } from "theme.slint";
import { PrimaryButton, SecondaryButton, DangerButton, InputField, PasswordField } from "components.slint";
import { ProfileUiData, CredentialUiData, SessionUiData, Sidebar, UnlockView, ProfileCard } from "views.slint";

export { ProfileUiData, CredentialUiData, SessionUiData }

export component AppWindow inherits Window {
    title: "EnvGuard";
    min-width: 900px;
    min-height: 600px;
    preferred-width: 1100px;
    preferred-height: 720px;
    background: Palette.bg-base;
    in-out property <int> active-nav: 0;
    in-out property <bool> vault-locked: true;
    in-out property <string> error-message: "";
    in-out property <int> active-session-count: 0;
    in-out property <[ProfileUiData]> profiles: [];
    in-out property <[CredentialUiData]> credentials: [];
    in-out property <[SessionUiData]> active-sessions: [];
    in-out property <[string]> scanned-env-files: [];
    in-out property <string> selected-profile-id: "";
    in-out property <string> selected-profile-name: "";
    in-out property <string> new-profile-name: "";
    in-out property <string> new-profile-desc: "";
    in-out property <string> new-credential-key: "";
    in-out property <string> new-credential-val: "";
    in-out property <string> new-cred-key: "";
    in-out property <string> new-cred-val: "";
    in-out property <string> scan-directory: "";

    callback unlock(string);
    callback lock-vault;
    callback create-profile(string, string);
    callback select-profile(string);
    callback delete-profile(string);
    callback add-credential(string, string, string);
    callback delete-credential(string);
    callback copy-to-clipboard(string);
    callback decrypt-credential(string) -> string;
    callback start-session(string);
    callback stop-session(string);
    callback scan-env-files(string);

    if vault-locked: UnlockView {
        error-text: root.error-message;
        unlock(pw) => { root.unlock(pw); }
    }
    if !vault-locked: HorizontalLayout {
        Sidebar {
            active-item: root.active-nav;
            active-session-count: root.active-session-count;
            navigate(item) => {
                root.active-nav = item;
                root.selected-profile-id = "";
            }
            lock-vault => { root.lock-vault(); }
        }
        Rectangle { width: 1px; background: Palette.border-subtle; }
        Rectangle {
            background: Palette.bg-base;
            horizontal-stretch: 1;
            if active-nav == 0 && selected-profile-id == "": VerticalLayout {
                padding: Tokens.space-6;
                spacing: Tokens.space-4;
                alignment: start;
                HorizontalLayout {
                    alignment: space-between;
                    Text {
                        text: "Project Profiles";
                        font-size: Typography.size-2xl;
                        font-weight: Typography.weight-bold;
                        color: Palette.text-primary;
                    }
                }
                HorizontalLayout {
                    spacing: Tokens.space-3;
                    InputField {
                        placeholder: "Profile name";
                        value <=> root.new-profile-name;
                        width: 200px;
                    }
                    InputField {
                        placeholder: "Description";
                        value <=> root.new-profile-desc;
                        width: 300px;
                    }
                    PrimaryButton {
                        text: "Create Profile";
                        clicked => {
                            root.create-profile(root.new-profile-name, root.new-profile-desc);
                            root.new-profile-name = "";
                            root.new-profile-desc = "";
                        }
                        y: 28px;
                    }
                }
                Rectangle { height: 1px; background: Palette.border-subtle; }
                if profiles.length == 0: Text {
                    text: "No profiles created yet. Use the form above to add one.";
                    font-size: Typography.size-base;
                    color: Palette.text-secondary;
                }
                VerticalLayout {
                    spacing: Tokens.space-4;
                    for p in profiles: ProfileCard {
                        profile: p;
                        clicked => {
                            root.selected-profile-id = p.id;
                            root.selected-profile-name = p.name;
                            root.select-profile(p.id);
                        }
                        start-session => {
                            root.start-session(p.id);
                        }
                    }
                }

            }
            if active-nav == 0 && selected-profile-id != "": VerticalLayout {
                padding: Tokens.space-6;
                spacing: Tokens.space-4;
                alignment: start;
                HorizontalLayout {
                    spacing: Tokens.space-4;
                    SecondaryButton {
                        text: "<- Back";
                        clicked => { root.selected-profile-id = ""; }
                    }
                    Text {
                        text: "Profile: " + root.selected-profile-name;
                        font-size: Typography.size-2xl;
                        font-weight: Typography.weight-bold;
                        color: Palette.text-primary;
                    }
                    DangerButton {
                        text: "Delete Profile";
                        clicked => {
                            root.delete-profile(root.selected-profile-id);
                            root.selected-profile-id = "";
                        }
                    }
                }
                Rectangle { height: 1px; background: Palette.border-subtle; }
                HorizontalLayout {
                    spacing: Tokens.space-3;
                    InputField {
                        placeholder: "Key (e.g. API_KEY)";
                        value <=> root.new-cred-key;
                        width: 200px;
                    }
                    InputField {
                        placeholder: "Value";
                        value <=> root.new-cred-val;
                        width: 300px;
                    }
                    PrimaryButton {
                        text: "Add Credential";
                        clicked => {
                            root.add-credential(root.selected-profile-id, root.new-cred-key, root.new-cred-val);
                            root.new-cred-key = "";
                            root.new-cred-val = "";
                        }
                        y: 28px;
                    }
                }
                Rectangle { height: 1px; background: Palette.border-subtle; }
                if credentials.length == 0: Text {
                    text: "No credentials in this profile yet. Add one above.";
                    font-size: Typography.size-base;
                    color: Palette.text-secondary;
                }
                for c in credentials: HorizontalLayout {
                    height: 48px;
                    alignment: start;
                    spacing: Tokens.space-4;
                    Text {
                        text: c.key;
                        font-size: Typography.size-base;
                        font-weight: Typography.weight-bold;
                        color: Palette.text-primary;
                        width: 200px;
                    }
                    Text {
                        text: c.value-revealed ? c.value-plaintext : "••••••••••••";
                        font-size: Typography.size-base;
                        color: Palette.text-secondary;
                        width: 200px;
                    }
                    SecondaryButton {
                        text: c.value-revealed ? "Hide" : "Reveal";
                        clicked => {
                            if (!c.value-revealed) {
                                c.value-plaintext = root.decrypt-credential(c.id);
                            } else {
                                c.value-plaintext = "";
                            }
                            c.value-revealed = !c.value-revealed;
                        }
                        height: 28px;
                    }
                    SecondaryButton {
                        text: "Copy";
                        clicked => { root.copy-to-clipboard(c.id); }
                        height: 28px;
                    }
                    DangerButton {
                        text: "Delete";
                        clicked => { root.delete-credential(c.id); }
                        height: 28px;
                    }
                }
            }
            if active-nav == 1: VerticalLayout {
                padding: Tokens.space-6;
                spacing: Tokens.space-4;
                alignment: start;
                Text {
                    text: "Active Runtime Sessions";
                    font-size: Typography.size-2xl;
                    font-weight: Typography.weight-bold;
                    color: Palette.text-primary;
                }
                Rectangle { height: 1px; background: Palette.border-subtle; }
                if active-sessions.length == 0: Text {
                    text: "No shell sessions currently active. Start one from the Profiles grid.";
                    font-size: Typography.size-base;
                    color: Palette.text-secondary;
                }
                for s in active-sessions: HorizontalLayout {
                    height: 48px;
                    alignment: start;
                    spacing: Tokens.space-4;
                    Text {
                        text: s.profile-name;
                        font-size: Typography.size-base;
                        font-weight: Typography.weight-bold;
                        color: Palette.text-primary;
                        width: 200px;
                    }
                    Text {
                        text: "PID: " + s.pid;
                        font-size: Typography.size-base;
                        color: Palette.text-secondary;
                        width: 100px;
                    }
                    Text {
                        text: s.started-at;
                        font-size: Typography.size-base;
                        color: Palette.text-muted;
                        width: 200px;
                    }
                    DangerButton {
                        text: "Stop Session";
                        clicked => { root.stop-session(s.id); }
                        height: 28px;
                    }
                }
            }
            if active-nav == 2: VerticalLayout {
                padding: Tokens.space-6;
                spacing: Tokens.space-4;
                alignment: start;
                Text {
                    text: ".env File Scanner";
                    font-size: Typography.size-2xl;
                    font-weight: Typography.weight-bold;
                    color: Palette.text-primary;
                }
                Rectangle { height: 1px; background: Palette.border-subtle; }
                HorizontalLayout {
                    spacing: Tokens.space-3;
                    InputField {
                        placeholder: "Directory absolute path";
                        value <=> root.scan-directory;
                        width: 400px;
                    }
                    PrimaryButton {
                        text: "Scan Directory";
                        clicked => { root.scan-env-files(root.scan-directory); }
                        y: 28px;
                    }
                }
                Rectangle { height: 1px; background: Palette.border-subtle; }
                if scanned-env-files.length == 0: Text {
                    text: "No .env files detected or scanned yet.";
                    font-size: Typography.size-base;
                    color: Palette.text-secondary;
                }
                for path in scanned-env-files: Text {
                    text: "Warning: Plaintext env file found at: " + path;
                    font-size: Typography.size-base;
                    color: Palette.danger;
                }
            }
            if active-nav == 3: VerticalLayout {
                padding: Tokens.space-6;
                spacing: Tokens.space-4;
                alignment: start;
                Text {
                    text: "Settings & System Diagnostics";
                    font-size: Typography.size-2xl;
                    font-weight: Typography.weight-bold;
                    color: Palette.text-primary;
                }
                Rectangle { height: 1px; background: Palette.border-subtle; }
                Text {
                    text: "EnvGuard v0.1.0";
                    font-size: Typography.size-base;
                    font-weight: Typography.weight-bold;
                    color: Palette.text-primary;
                }
                Text {
                    text: "Operating System Native Secrets Engine (Zero-Plaintext Model)";
                    font-size: Typography.size-sm;
                    color: Palette.text-secondary;
                }
                Text {
                    text: "Static linking: SQLCipher transparent database-at-rest encryption verified.";
                    font-size: Typography.size-sm;
                    color: Palette.success;
                }
            }
        }
    }
}
