import { Palette, Typography, Tokens } from "theme.slint";
import { PrimaryButton, SecondaryButton, DangerButton, IconButton, InputField, PasswordField } from "components.slint";

export struct ProfileUiData {
    id: string,
    name: string,
    description: string,
    credential-count: int,
    is-active: bool,
    session-count: int,
}

export struct CredentialUiData {
    id: string,
    key: string,
    value-revealed: bool,
    value-plaintext: string,
}

export struct SessionUiData {
    id: string,
    profile-name: string,
    shell: string,
    started-at: string,
    expires-at: string,
    pid: int,
    status: string,
}

export component Sidebar inherits Rectangle {
    in property <int> active-item: 0;
    in property <int> active-session-count: 0;
    callback navigate(int);
    callback lock-vault;
    width: Tokens.sidebar-width;
    background: Palette.sidebar-bg;
    VerticalLayout {
        padding: Tokens.space-4;
        spacing: Tokens.space-2;
        alignment: start;
        Text {
            text: "EnvGuard";
            font-size: Typography.size-lg;
            font-weight: Typography.weight-bold;
            color: Palette.text-primary;
            height: 36px;
        }
        Rectangle { height: 1px; background: Palette.border-subtle; }
        TouchArea {
            height: 36px;
            clicked => { root.navigate(0); }
            Rectangle {
                background: active-item == 0 ? Palette.sidebar-item-active : transparent;
                border-radius: 4px;
                Text {
                    x: Tokens.space-3;
                    y: (parent.height - self.height) / 2;
                    text: "+  Profiles";
                    font-size: Typography.size-base;
                    color: active-item == 0 ? Palette.text-primary : Palette.text-secondary;
                }
            }
        }
        TouchArea {
            height: 36px;
            clicked => { root.navigate(1); }
            Rectangle {
                background: active-item == 1 ? Palette.sidebar-item-active : transparent;
                border-radius: 4px;
                Text {
                    x: Tokens.space-3;
                    y: (parent.height - self.height) / 2;
                    text: "❯  Active Sessions (" + active-session-count + ")";
                    font-size: Typography.size-base;
                    color: active-item == 1 ? Palette.text-primary : Palette.text-secondary;
                }
            }
        }
        TouchArea {
            height: 36px;
            clicked => { root.navigate(2); }
            Rectangle {
                background: active-item == 2 ? Palette.sidebar-item-active : transparent;
                border-radius: 4px;
                Text {
                    x: Tokens.space-3;
                    y: (parent.height - self.height) / 2;
                    text: "/  .env Scanner";
                    font-size: Typography.size-base;
                    color: active-item == 2 ? Palette.text-primary : Palette.text-secondary;
                }
            }
        }
        TouchArea {
            height: 36px;
            clicked => { root.navigate(3); }
            Rectangle {
                background: active-item == 3 ? Palette.sidebar-item-active : transparent;
                border-radius: 4px;
                Text {
                    x: Tokens.space-3;
                    y: (parent.height - self.height) / 2;
                    text: "*  Settings";
                    font-size: Typography.size-base;
                    color: active-item == 3 ? Palette.text-primary : Palette.text-secondary;
                }
            }
        }
        Rectangle { vertical-stretch: 1; }
        SecondaryButton {
            text: "Lock Vault";
            clicked => { root.lock-vault(); }
        }
    }
}

export component UnlockView inherits Rectangle {
    in property <string> error-text: "";
    in-out property <string> password: "";
    in property <bool> vault-initialized: true;
    callback unlock(string);
    callback reset-vault();
    background: Palette.bg-base;
    Rectangle {
        width: 360px;
        height: 280px;
        background: Palette.bg-surface;
        border-radius: 8px;
        border-width: 1px;
        border-color: Palette.border-default;
        VerticalLayout {
            padding: Tokens.space-6;
            spacing: Tokens.space-4;
            alignment: center;
            Text {
                text: root.vault-initialized ? "Unlock Vault" : "Create Master Password";
                font-size: Typography.size-lg;
                font-weight: Typography.weight-semibold;
                color: Palette.text-primary;
                horizontal-alignment: center;
            }
            pw := PasswordField {
                placeholder: root.vault-initialized ? "Enter password to unlock" : "Set password for new vault";
                value <=> root.password;
                error-text: root.error-text;
            }
            PrimaryButton {
                text: root.vault-initialized ? "Unlock" : "Create Vault";
                clicked => { root.unlock(root.password); }
            }
            if root.vault-initialized: TouchArea {
                height: 24px;
                clicked => { root.reset-vault(); }
                Text {
                    text: "Reset and Wipe Vault";
                    font-size: Typography.size-xs;
                    color: Palette.danger;
                    horizontal-alignment: center;
                    y: (parent.height - self.height) / 2;
                }
            }
        }
    }
}

export component ProfileCard inherits Rectangle {
    in property <ProfileUiData> profile;
    callback clicked;
    callback start-session;
    height: 64px;
    background: Palette.bg-surface;
    border-radius: 6px;
    border-width: 1px;
    border-color: profile.is-active ? Palette.accent : Palette.border-default;
    HorizontalLayout {
        padding-left: Tokens.space-4;
        padding-right: Tokens.space-4;
        spacing: Tokens.space-4;
        alignment: space-between;
        VerticalLayout {
            alignment: center;
            spacing: 2px;
            HorizontalLayout {
                spacing: Tokens.space-2;
                alignment: start;
                if profile.is-active: Rectangle {
                    width: 6px;
                    height: 6px;
                    border-radius: Tokens.radius-full;
                    background: Palette.success;
                    y: 6px;
                }
                Text {
                    text: profile.name;
                    font-size: Typography.size-base;
                    font-weight: Typography.weight-semibold;
                    color: Palette.text-primary;
                }
            }
            if profile.description != "": Text {
                text: profile.description;
                font-size: Typography.size-xs;
                color: Palette.text-secondary;
                overflow: elide;
            }
        }
        HorizontalLayout {
            spacing: Tokens.space-4;
            alignment: end;
            VerticalLayout {
                alignment: center;
                Text {
                    text: profile.credential-count + " keys";
                    font-size: Typography.size-xs;
                    color: Palette.text-muted;
                }
            }
            VerticalLayout {
                alignment: center;
                PrimaryButton {
                    text: "Launch";
                    clicked => { root.start-session(); }
                    height: 24px;
                    min-width: 64px;
                }
            }
        }
    }
    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}
